<?xml version="1.0" encoding="utf-8"?>
<!--
    REPLACE your existing AndroidManifest.xml content with this.
    Keep your existing <application> attributes (icon, theme, etc.)
    and only replace the permissions + component declarations.
-->
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <!-- ===== PERMISSIONS ===== -->

    <!-- Required to fire alarms even in Doze mode -->
    <uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
    <uses-permission android:name="android.permission.WAKE_LOCK" />

    <!-- Exact alarms — required on Android 12+ (S / API 31) -->
    <uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
    <!-- On Android 13+ (T / API 33) you may also need this instead/additionally: -->
    <uses-permission android:name="android.permission.USE_EXACT_ALARM" />

    <!-- Foreground service -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
    <!-- Required on Android 14+ for media playback foreground service type -->
    <uses-permission android:name="android.permission.FOREGROUND_SERVICE_MEDIA_PLAYBACK" />

    <!-- Notifications — required on Android 13+ (T / API 33) -->
    <uses-permission android:name="android.permission.POST_NOTIFICATIONS" />

    <application
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:theme="@style/Theme.SalawatReminder">

        <activity
            android:name=".MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- ===== ALARM RECEIVER ===== -->
        <!-- exported=true required so AlarmManager can fire it when app is killed -->
        <receiver
            android:name=".AlarmReceiver"
            android:exported="true">
            <intent-filter>
                <action android:name="com.example.salawatreminder.PLAY_SOUND" />
                <action android:name="android.intent.action.BOOT_COMPLETED" />
                <!-- For some Xiaomi/OnePlus devices -->
                <action android:name="android.intent.action.QUICKBOOT_POWERON" />
            </intent-filter>
        </receiver>

        <!-- ===== STOP RECEIVER (from notification action) ===== -->
        <receiver
            android:name=".StopReceiver"
            android:exported="false" />

        <!-- ===== SOUND SERVICE (plays audio, short-lived) ===== -->
        <service
            android:name=".SoundService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

        <!-- ===== STATUS SERVICE (persistent notification) ===== -->
        <service
            android:name=".StatusService"
            android:exported="false"
            android:foregroundServiceType="mediaPlayback" />

    </application>

</manifest>
